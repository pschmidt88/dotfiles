:: default : yabai -m config active_window_opacity 1.0; yabai -m config normal_window_opacity 1.0;

cmd - return : /Applications/Alacritty.app/Contents/MacOS/alacritty 
cmd + shift - return : /Applications/Alacritty.app/Contents/MacOS/alacritty --command /opt/homebrew/bin/fish -l -c tmux new-session
cmd - p : /Applications/Obsidian.app/Contents/MacOS/Obsidian

# yabai shortcuts
ctrl + shift - 1 : yabai -m window --space browser
ctrl + shift - 2 : yabai -m window --space terminal
ctrl + shift - 3 : yabai -m window --space code
ctrl + shift - 4 : yabai -m window --space teams
ctrl + shift - 5 : yabai -m window --space misc
ctrl + shift - 6 : yabai -m window --space music
ctrl + shift - 7 : yabai -m window --space notes
# cmd + shift - 8 : yabai -m window --space 8
# cmd + shift - 9 : yabai -m window --space 9
# cmd + shift - 0 : yabai -m window --space 0
ctrl - 1 : yabai -m space --focus browser
ctrl - 2 : yabai -m space --focus terminal
ctrl - 3 : yabai -m space --focus code
ctrl - 4 : yabai -m space --focus teams
ctrl - 5 : yabai -m space --focus misc
ctrl - 6 : yabai -m space --focus music
ctrl - 7 : yabai -m space --focus notes
ctrl + shift - z : yabai -m space --display 2
ctrl + shift - x : yabai -m space --display 1

# focus windows
ctrl - h :  yabai -m window --focus west
ctrl - l :  yabai -m window --focus east

ctrl + shift - h : yabai -m window --focus west
ctrl + shift - l : yabai -m window --focus east

ctrl + shift - left : yabai -m window --focus west
ctrl + shift - right : yabai -m window --focus east

# move windows
ctrl + alt - h : yabai -m window --swap west
ctrl + alt - l : yabai -m window --swap east

ctrl + alt - left : yabai -m window --swap west
ctrl + alt - right : yabai -m window --swap east
ctrl + alt - up : yabai -m window --swap north
ctrl + alt - down : yabai -m window --swap south

# resize
:: resize @ : yabai -m config active_window_opacity 1.0; yabai -m config normal_window_opacity 0.8;

# balance it out
ctrl + shift - b: yabai -m space --balance

ctrl + alt - r ; resize
ctrl - escape ; resize

resize < escape ; default

resize < right : yabai -m window --resize right:25:0
resize < alt - right : yabai -m window --resize right:100:0
resize < left : yabai -m window --resize right:-25:0
resize < alt - left : yabai -m window --resize right:-100:0

# focus mode, center window by adding padding all around. 
ctrl + shift - f: yabai -m config top_padding 120; yabai -m config bottom_padding 120; yabai -m config left_padding 480; yabai -m config right_padding 480 

# reload yabai config
ctrl + shift - c: yabai --restart-service
